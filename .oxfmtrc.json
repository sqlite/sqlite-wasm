{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "insertPragma": false,
  "printWidth": 100,
  "proseWrap": "always",
  "requirePragma": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "ignorePatterns": ["/src/bin", "/dist", "/node_modules", "package.json"]
}
